<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>KRACIT-prepare your interview</title>
  <link rel="stylesheet" href="css/fr11.css" />
</head>
<body>
  <div class="hero-container">
    <header class="navbar">
      <div class="logo">KRACIT</div>
      <nav class="nav-links">
        <a href="#home">Home</a>
        <a href="#about">About</a>
        <a href="#features">Feature</a>
        <a href="#login">Log in</a>
        
      </nav>
      <button class="get-started" onclick="window.location.href='/signup'">Get Started now</button>

    </header>

    <section class="hero-content" id="home">
      <div class="text-content">
        <p class="tagline">Your Career, Evolved.</p>
        <h1>Unlock Your<br>
         Potential</h1>
         <br>
        <p class="description">
          Kracit uses AI to provide personalized career guidance, helping you ace interviews and land your dream job efficiently.
        </p>
        
        <div class="hero-buttons">
          <button class="get-started" onclick="window.location.href='/signup'">Get Started</button>

        </div>
      </div>
    </section>
  </div>

<!--about section-->
<section class="about-section" id="about">
  <div class="about-content">
    <div class="about-image">
      <img src="/images/lside.png" alt="About illustration" />
    </div>
    <div class="about-text">
      <div class="tagline">Your Career, Evolved.</div>
      <h2>About Kracit</h2>
      <p class="main">
        Kracit is your AI-powered career companion, offering CV analysis, study
        materials, aptitude test, and mock interview simulations.
      </p>
      <p>
        We leverage AI to provide personalized career guidance, helping you ace
        interviews and land your dream job efficiently and effectively.
      </p>
    </div>
  </div>
</section>


<section class="features-section" id="features">
  <div class="features-header">
  <div class="features-heading-text">
    <p class="features-subtitle">Key Features</p>
    <h2 class="features-title">Our Features</h2>
  </div>
  <p class="features-description">
    Our platform offers AI-driven CV analysis, study material, aptitude tests, and mock interview simulations for career success.
  </p>
</div>


  <div class="features-grid">
    <div class="feature-item">
      <div class="feature-icon yellow-ring">
        <img src="/images/i2.png" alt="CV Analysis Icon">
      </div>
      <h3>CV Analysis</h3>
      <p>AI-powered CV analysis provides instant feedback, enhancing your resume for optimal impact and results.</p>
    </div>

    <div class="feature-item">
      <div class="feature-icon pink-ring">
        <img src="/images/i3.png" alt="Study Material Icon">
      </div>
      <h3>Study Material</h3>
      <p>Access curated study material tailored to your needs, ensuring comprehensive preparation and knowledge retention.</p>
    </div>

    <div class="feature-item">
      <div class="feature-icon blue-ring">
        <img src="/images/i4.png" alt="Mock Interview Icon">
      </div>
      <h3>Mock Interview</h3>
      <p>Experience realistic interview simulations with instant feedback, refining your skills and boosting confidence.</p>
    </div>
  </div>

  <div class="feature-item feature-bottom">
    <div class="feature-icon green-ring">
      <img src="/images/i1.png" alt="Aptitude Test Icon">
    </div>
    <h3>Aptitude Test</h3>
    <p>Evaluate and enhance your problem-solving skills with tailored aptitude tests covering logical reasoning, math, and verbal ability.</p>
  </div>
</section>

<!--login section-->
<section class="login-section" id="login">
  <div class="login-container">
    <h2>Login</h2>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <form action="/login" method="POST">
      <label for="email">Email</label>
      <input type="email" name="email" id="email" placeholder="username@gmail.com" required />

      <label for="password">Password</label>
      <input type="password" name="password" id="password" placeholder="Password" required />

      <div class="forgot-password">
  <a href="/forgot-password">Forgot Password?</a>
</div>

      <button type="submit" class="login-btn">Sign in</button>

      <div class="register-link">
        <a href="/signup">Register here</a>
      </div>
    </form>
  </div>
</section>


<section class="feedback-section" id="feedback">
  <div class="feedback-container">
    <h2>We would love your feedback </h2>
    
     email us:-  somil2957@gmail.com<br>
     2nd email:- sumit12fire@gmail.com<br>
     3rd email:- sumedh.kathaneking@gmail.com<br>
     <br>
     <br>
     Developed by:- Sumit Patel, Somil Jain, Sumedh Kathane.
  </div>
</section>



  <script src="js/fr21.js"></script>
</body>
</html>
